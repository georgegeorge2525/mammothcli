{
  "name": "mammothcli",
  "version": "1.0.0",
  "description": "Mammoth — autonomous coding agent framework. Multi-provider, multi-agent, memory-backed, runs in your terminal. Powered by DeepSeek-V4, Claude, OpenAI, and more.",
  "type": "module",
  "main": "src/main.tsx",
  "bin": {
    "mammothcli": "./src/main.tsx"
  },
  "scripts": {
    "start": "bun run src/main.tsx",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit --pretty",
    "prepublishOnly": "tsc --noEmit"
  },
  "files": [
    "src/",
    "services/",
    "memory/",
    "engine/",
    "providers/",
    "contexts/",
    "types/",
    "constants/"
  ],
  "keywords": [
    "ai",
    "coding-assistant",
    "cli",
    "deepseek",
    "mammoth",
    "tui",
    "agent",
    "code-review",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/georgegeorge2525/mammothcli"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "ink": "^5.0.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "bun-types": "^1.2.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
