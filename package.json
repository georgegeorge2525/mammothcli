{
  "name": "mammothcli",
  "version": "1.0.0",
  "description": "Mammoth — sovereign AI coding assistant CLI. Ask it to code, review, debug, or build. Local-first, powered by DeepSeek-V4.",
  "type": "module",
  "main": "main-tui.tsx",
  "bin": {
    "mammothcli": "./main-tui.tsx"
  },
  "scripts": {
    "start": "bun run main-tui.tsx",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit --pretty",
    "prepublishOnly": "tsc --noEmit"
  },
  "files": [
    "main-tui.tsx",
    "MammothApp.tsx",
    "MammothLoop.ts",
    "MammothPrompt.tsx",
    "MessageList.tsx",
    "AgentStatus.tsx",
    "AgentRunner.ts",
    "Commands.ts",
    "ToolRegistry.ts",
    "PermissionManager.ts",
    "MCPManager.ts",
    "SessionStore.ts",
    "system-prompt.txt",
    "services/",
    "memory/",
    "engine/",
    "providers/",
    "contexts/",
    "types/",
    "constants/"
  ],
  "keywords": [
    "ai",
    "coding-assistant",
    "cli",
    "deepseek",
    "mammoth",
    "tui",
    "agent",
    "code-review",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/george/mammothcli"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "ink": "^5.0.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "bun-types": "^1.2.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
