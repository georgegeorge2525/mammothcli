{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "outDir": "dist",
    "baseUrl": ".",
    "allowImportingTsExtensions": true,
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "services/**/*.ts", "memory/**/*.ts", "engine/**/*.ts", "providers/**/*.ts", "contexts/**/*.ts", "types/**/*.ts", "constants/**/*.ts"],
  "exclude": ["node_modules", "dist", ".mammoth"]
}
